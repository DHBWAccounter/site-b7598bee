{
  "name": "Tiny Waitlist",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "predev": "CONVEX_AGENT_MODE=anonymous convex dev --once",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern \"convex/_generated/**\""
  },
  "dependencies": {
    "convex": "^1.31.2",
    "next": "^15.5.9",
    "react": "^19.0.3",
    "react-dom": "^19.0.3",
    "lucide-react": "^0.469.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.9",
    "npm-run-all2": "^8.0.4",
    "typescript": "^5",
    "tailwindcss": "^3.4",
    "postcss": "^8",
    "autoprefixer": "^10",
    "serve": "^14"
  }
}
